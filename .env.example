# Copy this file to `.env` and fill in your values.

# --- Provider (OpenAI-compatible) ---
# Works with OpenAI, Groq, OpenRouter, Ollama, etc.
OPENAI_API_KEY=your-api-key-here

# Optional: point at another OpenAI-compatible provider.
# Groq (free):       https://api.groq.com/openai/v1
# OpenRouter:        https://openrouter.ai/api/v1
# Ollama (local):    http://localhost:11434/v1
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Model id for the chosen provider.
OPENAI_MODEL=gpt-4o-mini

# --- Generation (optional) ---
# OPENAI_TEMPERATURE=0.7
# MAX_HISTORY_MESSAGES=20

# --- Cost estimate per 1k tokens (optional; 0 = free providers like Groq) ---
# PROMPT_COST_PER_1K=0.0
# COMPLETION_COST_PER_1K=0.0

# --- Persistence (optional; any SQLAlchemy URL) ---
# DATABASE_URL=sqlite:///chatbot.db
